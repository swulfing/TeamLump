lambda >= 1 ~ "Positive"
))
iteration_bins <- iteration %>%
mutate(PopDynamics = case_when(
lambda < 1 ~ "Decrease",
lambda >= 1 & lambda < 1.25 ~ "0-25",
lambda >= 1.25 & lambda < 1.5 ~ "25-50",
lambda >= 1.5 & lambda < 1.75 ~ "50-75",
lambda >= 1.75 & lambda < 2 ~ "75-100"
))
